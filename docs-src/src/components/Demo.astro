---
const base = import.meta.env.BASE_URL;
---
<section class="demo" id="demo" style="background: var(--white)"";>
  <div class="wrap">
    <h2 class="section-title fade">Demos</h2>
    <div class="pills fade" role="tablist">
      <button class="pill active" data-tab="0" role="tab" aria-selected="true" aria-controls="demo-vid-0">v2.0 — 23/04/2026</button>
      <button class="pill" data-tab="1" role="tab" aria-selected="false" aria-controls="demo-vid-1">v1.0 — 31/12/2025</button>
    </div>
    <div class="video-wrap fade">
      <video id="demo-vid-0" class="vid active" src={`${base}videos/demo-v2-2.mp4`} controls autoplay muted loop playsinline aria-label="Demo of Palette app version 2.0"></video>
      <video id="demo-vid-1" class="vid" src={`${base}videos/demo-v1-2.mp4`} control autoplay muted loop playsinline aria-label="Demo of Palette app version 1.0"></video>
    </div>
  </div>
</section>

<style>
  .pills { display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .pill {
    padding: 0.6rem 1.6rem; border-radius: 50px; border: 1.5px solid var(--gold);
    background: transparent; color: var(--gold); font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.2em; cursor: pointer;
    transition: background 0.3s, color 0.3s, box-shadow 0.3s;
  }
  .pill:hover { background: rgba(212,175,55,0.1); }
  .pill.active {
    background: var(--gold);
    color: #fff; border-color: transparent;
    box-shadow: 0 0 20px rgba(212,175,55,0.3);
  }
  .video-wrap {
    max-width: 360px;
    margin: 0 auto;
    position: relative; border-radius: 20px; overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    border: 1px solid rgba(212,175,55,0.2);
    transition: box-shadow 0.3s;
  }
  .video-wrap:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.16); }
  .vid {
    width: 100%; display: block;
    transition: opacity 0.4s ease;
  }
  .vid:not(.active) {
    opacity: 0; position: absolute; inset: 0; height: 100%; object-fit: cover;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .vid, .pill, .video-wrap { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('.demo .pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = Number(btn.dataset.tab);
      const section = btn.closest('.demo');
      const vids = section.querySelectorAll('.vid');
      section.querySelectorAll('.pill').forEach((p, j) => {
        const on = j === i;
        p.classList.toggle('active', on);
        p.setAttribute('aria-selected', String(on));
      });
      vids.forEach((v, j) => {
        const on = j === i;
        v.classList.toggle('active', on);
        on ? v.play() : v.pause();
      });
    });
  });
</script>
